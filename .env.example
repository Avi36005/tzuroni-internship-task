# LLM Provider Credentials
# Provider is auto-selected: Groq is preferred when GROQ_API_KEY is set, else OpenRouter.
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Groq API (OpenAI-compatible endpoint, free models such as llama-3.1-8b-instant)
GROQ_API_KEY=your_groq_api_key_here
# Optional second Groq key: enables round-robin + rate-limit failover (doubles free TPM)
GROQ_API_KEY_FALLBACK=your_groq_api_key_fallback

# Model id for the selected provider (e.g. llama-3.3-70b-versatile for Groq,
# google/gemini-2.5-flash for OpenRouter)
LLM_MODEL=llama-3.1-8b-instant

# Optional explicit OpenAI-compatible base URL override (leave blank to auto-select)
LLM_BASE_URL=

# Use the Nous Research Hermes Agent framework (pip install hermes-agent) as the
# reasoning backend when installed. Set to false to use the direct API client instead.
USE_HERMES=true

# Apify API Token (Optional, fallback is free Open-Meteo & NOAA)
APIFY_TOKEN=your_apify_token_here

# Database Configuration (SQLite)
DATABASE_URL=sqlite+aiosqlite:///weather_trading.db

# Trading Parameters
STARTING_BALANCE=10000.0
KELLY_FRACTION=0.25
MAX_EXPOSURE_PER_TRADE=0.10
DAILY_LOSS_LIMIT=0.05

# Telegram Notification (Optional)
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
